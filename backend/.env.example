# Copy to .env and fill in. All vars are prefixed QUORUM_.

# SQLite (async) database location.
QUORUM_DATABASE_URL=sqlite+aiosqlite:///./quorum.db

# Fernet key for encrypting provider API keys at rest. Generate with:
#   python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
# QUORUM_ENCRYPTION_KEY=

# Optional fallback provider keys (users can also configure these from the UI).
# QUORUM_ANTHROPIC_API_KEY=
# QUORUM_OPENAI_API_KEY=
# QUORUM_GOOGLE_API_KEY=
# QUORUM_GROQ_API_KEY=
# QUORUM_MISTRAL_API_KEY=
